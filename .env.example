# Copy to apps/api/.env (never commit real values)
# Reuse Gemini keys from blog-pipeline:
#   C:\Users\Intellian\Local Sites\9ruinfo\tools\blog-pipeline\.env

PORT=3011
CORS_ORIGIN=http://localhost:8081,*

GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-lite-latest

# Optional: WordPress publish (same as 9ruDocs / blog-pipeline)
WP_SITE_URL=https://9ruinfo.com
WP_USERNAME=
WP_APP_PASSWORD=

# Google Maps / Directions (API 서버 교통 추정 + 모바일 지도)
# 발급·제한·검증 가이드: docs/GOOGLE-MAPS-API-KEY.md
# 모바일은 apps/mobile/.env 의 EXPO_PUBLIC_GOOGLE_MAPS_API_KEY 사용 (app.config.js → Manifest 주입)
# 권장: 모바일=Maps SDK 제한 키 / 서버=Directions 전용 키
# ⚠ 모바일 키는 빌드 타임 주입 → APK 재빌드·재설치 필요 (설치 후 .env만 바꿔도 Manifest는 안 바뀜)
# GOOGLE_MAPS_API_KEY=
# EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=
# LAN: EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:3011
# Cloudways(9ruDocs와 별개): EXPO_PUBLIC_API_BASE_URL=https://YOUR-TRIP-HOST.cloudwaysapps.com/apps/api
# 가이드: docs/CLOUDWAYS.md

# 일본 대중교통 파트너 (선택) — Google Directions는 JP transit 미지원
# 가이드: docs/JP-TRANSIT-PARTNER.md
# JP_TRANSIT_PROVIDER=
# NAVITIME_API_KEY=
# NAVITIME_API_HOST=
# NAVITIME_CID=
# NAVITIME_RAPIDAPI_HOST=

# 국내 Naver Maps (스캐폴드 — 한국 도시용, 도쿄 MVP 불필요)
# NAVER_MAP_CLIENT_ID=
# NAVER_MAP_CLIENT_SECRET=
