{
  "name": "@9rutrip/mobile",
  "version": "0.0.1",
  "private": true,
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "start:dev": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "prebuild:android": "expo prebuild --platform android --clean",
    "android:usb": "expo run:android --device",
    "android:apk": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/build-release-apk.ps1",
    "android:release": "expo run:android --variant release --device",
    "android:devices": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/list-devices.ps1",
    "android:install": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/install-usb.ps1",
    "android:install:release": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/install-usb.ps1 -Release",
    "android:eas": "eas build --platform android --profile preview",
    "android:eas:dev": "eas build --platform android --profile development",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~55.0.24",
    "expo-asset": "~55.0.17",
    "expo-clipboard": "~55.0.15",
    "expo-constants": "~55.0.16",
    "expo-dev-client": "~55.0.37",
    "expo-file-system": "~55.0.20",
    "expo-font": "~55.0.7",
    "expo-image-picker": "~55.0.20",
    "expo-location": "~55.1.12",
    "expo-notifications": "~55.0.25",
    "expo-status-bar": "~55.0.6",
    "react": "19.2.0",
    "react-native": "0.83.6",
    "react-native-draggable-flatlist": "^4.0.3",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-maps": "1.26.20",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-worklets": "0.7.2"
  },
  "devDependencies": {
    "@babel/core": "^7.26.10",
    "@types/react": "~19.2.0",
    "babel-preset-expo": "~55.0.0",
    "eas-cli": "^16.32.0",
    "typescript": "~5.9.2"
  }
}
