# Copy to apps/mobile/.env (never commit real values)
# Expo loads EXPO_PUBLIC_* automatically (SDK 49+)
# 발급·제한·검증 가이드: docs/GOOGLE-MAPS-API-KEY.md

# Google Maps (해외 도시 · Android googleMaps.apiKey / iOS googleMapsApiKey 로 주입)
# Maps SDK for Android 전용 키 권장 (패키지 com.nineru.trip + SHA-1)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# API (에뮬레이터 기본은 코드 내 10.0.2.2:3011)
# EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:3011

# 국내(네이버) 맵 — 스캐폴드만, 도쿄 MVP에는 불필요
# EXPO_PUBLIC_NAVER_MAP_CLIENT_ID=
