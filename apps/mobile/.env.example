# Copy to apps/mobile/.env (never commit real values)
# Expo loads EXPO_PUBLIC_* automatically (SDK 49+)
# 발급·제한·검증 가이드: docs/GOOGLE-MAPS-API-KEY.md
# USB 실기기 빌드: apps/mobile/docs/ANDROID-USB-BUILD.md

# Google Maps (해외 도시 · Android googleMaps.apiKey / iOS googleMapsApiKey 로 주입)
# Maps SDK for Android 전용 키 권장 (패키지 com.nineru.trip + SHA-1)
# ⚠ Manifest에 키가 들어가려면 APK/개발 빌드를 다시 만들어야 함
#    (.env만 바꾸고 재설치 없이 실행하면 지도 타일은 안 뜸 · 크래시는 JS에서 방지)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# API — 에뮬레이터 기본은 코드의 10.0.2.2:3011
# USB 실기기(LAN): PC LAN IP (ipconfig) — 같은 Wi‑Fi 필수
# EXPO_PUBLIC_API_BASE_URL=http://192.168.0.10:3011
# 외부망(Cloudways): 9ruDocs URL과 별개 — docs/CLOUDWAYS.md
# EXPO_PUBLIC_API_BASE_URL=https://YOUR-TRIP-HOST.cloudwaysapps.com/apps/api

# 국내(네이버) 맵 — 스캐폴드만, 도쿄 MVP에는 불필요
# EXPO_PUBLIC_NAVER_MAP_CLIENT_ID=

# (선택) EAS 클라우드 빌드 시 프로젝트 ID
# EAS_PROJECT_ID=
