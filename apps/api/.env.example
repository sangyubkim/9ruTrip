# Copy to .env — never commit secrets
PORT=3011
CORS_ORIGIN=http://localhost:8081,*

GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-lite-latest
LLM_TIMEOUT_MS=90000

# WordPress (9ruDocs / blog-pipeline 과 동일). WP_BASE_URL 도 허용
WP_SITE_URL=https://9ruinfo.com
WP_USERNAME=
WP_APP_PASSWORD=

# Google Maps Directions (실시간 구간 추정). 없으면 하버사인 폴백
# GOOGLE_MAPS_API_KEY=

# Naver Maps (국내 도시 스캐폴드)
# NAVER_MAP_CLIENT_ID=
# NAVER_MAP_CLIENT_SECRET=
