# Copy to .env — never commit secrets
PORT=3011
CORS_ORIGIN=http://localhost:8081,*
# Cloudways: 프록시가 넘기는 포트로 PORT 맞춤. 공개 URL은 …/apps/api
# (9ruDocs와 별도 앱 권장 — docs/CLOUDWAYS.md)

GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-lite-latest
LLM_TIMEOUT_MS=90000

# WordPress (9ruDocs / blog-pipeline 과 동일). WP_BASE_URL 도 허용
WP_SITE_URL=https://9ruinfo.com
WP_USERNAME=
WP_APP_PASSWORD=

# Google Maps Directions (실시간 구간 추정 + 모드 비교). 없으면 모드별 하버사인 폴백
# 발급·제한·검증: docs/GOOGLE-MAPS-API-KEY.md
# 서버 키는 Directions만 허용 (Android 제한 없는 키 권장)
# GOOGLE_MAPS_API_KEY=

# 일본 대중교통 파트너 (선택). Google Directions는 JP transit 미지원.
# 미설정 시: 하버사인 추정 + Yahoo/Google deep link
# 가이드: docs/JP-TRANSIT-PARTNER.md
JP_TRANSIT_PROVIDER=
NAVITIME_API_KEY=
# NAVITIME_API_HOST=
# NAVITIME_CID=
# NAVITIME_RAPIDAPI_HOST=

# Naver Maps (국내 도시 스캐폴드)
# NAVER_MAP_CLIENT_ID=
# NAVER_MAP_CLIENT_SECRET=
