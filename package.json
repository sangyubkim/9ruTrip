{
  "name": "9rutrip",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "api": "node apps/api/server.mjs",
    "install:mobile": "npm install --prefix apps/mobile",
    "mobile": "npm run start --prefix apps/mobile",
    "mobile:dev": "npm run start:dev --prefix apps/mobile",
    "android:usb": "npm run android:usb --prefix apps/mobile",
    "android:release": "npm run android:release --prefix apps/mobile",
    "android:apk": "npm run android:apk --prefix apps/mobile",
    "android:install": "npm run android:install --prefix apps/mobile",
    "android:install:release": "npm run android:install:release --prefix apps/mobile",
    "android:devices": "npm run android:devices --prefix apps/mobile",
    "android:build-install": "powershell -NoProfile -ExecutionPolicy Bypass -File ..\\scripts\\build-install-apk.ps1 -Project 9ruTrip -Mode BuildInstall",
    "shared:build": "npm run build --prefix packages/shared",
    "typecheck": "npm run build --prefix packages/shared && npx tsc -p apps/mobile --noEmit",
    "test": "npm run test --prefix apps/api"
  },
  "devDependencies": {
    "typescript": "~5.9.2"
  }
}
